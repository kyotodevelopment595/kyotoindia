{% schema %}
{
  "name": "Sticky Cards with Images",
  "settings": [
    {
      "type": "text",
      "id": "title_1",
      "label": "Card 1 Title",
      "default": "First sticky card title"
    },
    {
      "type": "textarea",
      "id": "description_1",
      "label": "Card 1 Description",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit."
    },
    {
      "type": "text",
      "id": "button_text_1",
      "label": "Card 1 Button Text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link_1",
      "label": "Card 1 Button Link"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Card 1 Image"
    },
    {
      "type": "text",
      "id": "title_2",
      "label": "Card 2 Title",
      "default": "Second sticky card title"
    },
    {
      "type": "textarea",
      "id": "description_2",
      "label": "Card 2 Description",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit."
    },
    {
      "type": "text",
      "id": "button_text_2",
      "label": "Card 2 Button Text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Card 2 Button Link"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Card 2 Image"
    },
    {
      "type": "text",
      "id": "title_3",
      "label": "Card 3 Title",
      "default": "Third sticky card title"
    },
    {
      "type": "textarea",
      "id": "description_3",
      "label": "Card 3 Description",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit."
    },
    {
      "type": "text",
      "id": "button_text_3",
      "label": "Card 3 Button Text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link_3",
      "label": "Card 3 Button Link"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Card 3 Image"
    }
  ],
  "presets": [
    {
      "name": "Sticky Cards with Images",
      "category": "Custom Sections"
    }
  ]
}
{% endschema %}

<style>
.sticky-scroll-container {
  position: relative;
  background: #fff;
  margin: 8rem;
  overflow: hidden;
}

.sticky-card-wrapper {
  height: 70vh;
  position: relative;
}

.sticky-card-container {
  border-radius: 5rem;
  display: flex;
  height: 70vh;
  width: 100%;
  position: sticky;
  top: 0;
  background: #fff;
  overflow: hidden;
}

.sticky-card {
  width: 50%;
  background: #1a1b2f;
  color: white;
  padding: 4rem 3rem;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.5s ease;
}

.sticky-card.active {
  opacity: 1;
}

.sticky-card__title {
  color: white;
  font-size: 3.5rem;
  font-weight: 500;
  margin-bottom: 1.5rem;
  line-height: 1.2;
}

.sticky-card__description {
  font-size: 1.25rem;
  color: white;
  margin-bottom: 2rem;
  line-height: 1.6;
}

.sticky-card__button {
  display: inline-flex;
  align-items: center;
  background: white;
  color: #1a1b2f;
  padding: 1rem 2rem;
  border-radius: 100px;
  text-decoration: none;
  font-weight: 500;
  transition: all 0.3s ease;
  width: fit-content;
}

.sticky-card__button:hover {
  transform: translateX(10px);
}

.sticky-card__image-container {
  width: 50%;
  position: relative;
  opacity: 0;
  transition: opacity 0.5s ease;
}

.sticky-card__image-container.active {
  opacity: 1;
}

.sticky-card__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

@media screen and (max-width: 768px) {
  .sticky-card-container {
    flex-direction: column;
    height: auto;
    position: relative;
  }
  
  .sticky-card,
  .sticky-card__image-container {
    width: 100%;
    height: auto;
  }
  
  .sticky-card {
    padding: 3rem 2rem;
  }
  
  .sticky-card__image-container {
    min-height: 400px;
  }
  
  .sticky-card-wrapper {
    height: auto;
    margin-bottom: 2rem;
  }
}
</style>

<div class="sticky-scroll-container">
  {% for i in (1..3) %}
    {% assign title_key = 'title_' | append: i %}
    {% assign description_key = 'description_' | append: i %}
    {% assign button_text_key = 'button_text_' | append: i %}
    {% assign button_link_key = 'button_link_' | append: i %}
    {% assign image_key = 'image_' | append: i %}
    
    <div class="sticky-card-wrapper" data-card="{{ i }}">
      <div class="sticky-card-container">
        <div class="sticky-card" id="card-{{ i }}">
          <h2 class="sticky-card__title">{{ section.settings[title_key] }}</h2>
          <div class="sticky-card__description">{{ section.settings[description_key] }}</div>
          {% if section.settings[button_link_key] != blank %}
            <a href="{{ section.settings[button_link_key] }}" class="sticky-card__button">
              {{ section.settings[button_text_key] }}
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </a>
          {% endif %}
        </div>
        <div class="sticky-card__image-container" id="image-{{ i }}">
          {% if section.settings[image_key] != blank %}
            {{ section.settings[image_key] | image_url: width: 1500 | image_tag: 
              class: 'sticky-card__image',
              loading: 'lazy',
              alt: section.settings[title_key]
            }}
          {% else %}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'sticky-card__image' }}
          {% endif %}
        </div>
      </div>
    </div>
  {% endfor %}
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const options = {
    root: null,
    rootMargin: '-50% 0px -50% 0px',
    threshold: 0
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const cardNum = entry.target.dataset.card;
        document.querySelector(`#card-${cardNum}`).classList.add('active');
        document.querySelector(`#image-${cardNum}`).classList.add('active');
      } else {
        const cardNum = entry.target.dataset.card;
        document.querySelector(`#card-${cardNum}`).classList.remove('active');
        document.querySelector(`#image-${cardNum}`).classList.remove('active');
      }
    });
  }, options);

  document.querySelectorAll('.sticky-card-wrapper').forEach(wrapper => {
    observer.observe(wrapper);
  });
});
</script>