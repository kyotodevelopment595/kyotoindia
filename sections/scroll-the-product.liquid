{{ 'slick.min.css' | asset_url | stylesheet_tag }}
{{ 'scroll-the-product.css' | asset_url | stylesheet_tag }}
<script src="{{ 'slick.min.js' | asset_url }}"></script>     
<style>
  
  #QuotesSection-{{ section.id }}  {
    background-color: {{ section.settings.color_bg }};
  }
  #QuotesSection-{{ section.id }} .quote,
  #QuotesSection-{{ section.id }} .quote-author,#QuotesSection-{{ section.id }} .quote-job {
    color: {{ section.settings.color_text }};
  }  
   .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  
   {% for block in section.blocks %}
    .hotspot-block .dt-sc-hotspot-item{{forloop.index}} {
      top: {{ block.settings.top_position }}%;
      left: {{ block.settings.left_position }}%;
      height: fit-content;
      max-width: fit-content;
      }
    .hotspot-block .dt-sc-hotspot-item2.block-type-product{ z-index:1 !important; }
    .hotspot-block .dt-sc-hotspot-item{{forloop.index}}.block-type-product.open { z-index: 999;}
    {% endfor %}
  
  {%- if section.settings.spot_image == blank %}  
      .shop-hot-spot{ width: 100%; }
  {%- endif -%}
 .scroll-the-product .product-section:after{
   content: "";
   background:url({{ section.settings.product_bg | image_url: width: 1920 }});
    position: absolute;
    right: 0;
    left: 0;
    width: 100%;
    height: 100%; 
    top:0;
    bottom:0; 
    z-index:-1;
    border-radius:0;
 }
  .scroll-the-product .shop-hot-spot:after{
    content: "";
   background:url({{ section.settings.banner_bg | image_url: width: 1920 }});
    position: absolute;
    right: 0;
    left: 0;
    width: 100%;
    height: 100%; 
    top:0;
    bottom:0; 
    z-index:-1;
    border-radius:0;
  }
  image-scroll-slider .swiper.swiper-initialized { max-height: 780px; overflow: hidden; }  
   @media screen and (max-width: 780px) {
     image-scroll-slider .swiper.swiper-initialized{max-height:450px;}
    }
</style>

<div id="section-{{ section.id }}" class="scroll-the-product  {{ section.settings.custom_class_name }}  {{ section.settings.product_style }} color-{{ section.settings.color_scheme }} gradient{% if section.settings.title == blank %} no-heading{% endif %}">
<div class="{% if section.settings.page_full_width %} page-full-width {% else %} page-width {% endif %} {% if section.settings.page_full_width_spacing %} page-full-width_spacing {% endif %} section-{{ section.id }}-padding isolate">
<div class="row">    
  <div class="module home-testimonials ready">
    <div class="module-body">
    <scroll-the-product>
      <div class="home-product-container" id="shop-look-selector-{{ section.id }}">
         <div class="shop-hot-spot">
         <image-scroll-slider>
    <div data-slider-options='{"loop": "1","desktop": "1", "laptop": "1", "tablet": "1","mobile": "1","auto_play": "false"}'>
      <div class="swiper" data-swiper-slider>           
              <div class="swiper-wrapper">
                 {% for block in section.blocks %}
               <div class="banner-image swiper-slide">                 
                 {%- if block.settings.spot_image != blank %}  
                <img
                            srcset="{%- if block.settings.spot_image.width >= 375 -%}{{ block.settings.spot_image | image_url: width: 375 }} 375w,{%- endif -%}
                            {%- if block.settings.spot_image.width >= 550 -%}{{ block.settings.spot_image | image_url: width: 550 }} 550w,{%- endif -%}
                            {%- if block.settings.spot_image.width >= 750 -%}{{ block.settings.spot_image | image_url: width: 750 }} 750w,{%- endif -%}
                            {%- if block.settings.spot_image.width >= 1100 -%}{{ block.settings.spot_image | image_url: width: 1100 }} 1100w,{%- endif -%}
                            {%- if block.settings.spot_image.width >= 1500 -%}{{ block.settings.spot_image | image_url: width: 1500 }} 1500w,{%- endif -%}
                            {%- if block.settings.spot_image.width >= 1780 -%}{{ block.settings.spot_image | image_url: width: 1780 }} 1780w,{%- endif -%}
                            {%- if block.settings.spot_image.width >= 2000 -%}{{ block.settings.spot_image | image_url: width: 2000 }} 2000w,{%- endif -%}
                            {%- if block.settings.spot_image.width >= 3000 -%}{{ block.settings.spot_image | image_url: width: 3000 }} 3000w,{%- endif -%}
                            {%- if block.settings.spot_image.width >= 3840 -%}{{ block.settings.spot_image | image_url: width: 3840 }} 3840w,{%- endif -%}
                            {{ block.settings.spot_image | image_url }} {{ section.settings.spot_image.width }}w"
                            sizes="100vw"
                            src="{{ block.settings.spot_image | image_url: width: 1500 }}"
                            loading="lazy"
                            class="dt-sc-hotspot-image"
                            alt="{{ block.settings.spot_image.alt | escape }}"
                            width="{{ block.settings.spot_image.width }}"
                            height="{{ block.settings.spot_image.height }}"
                          >  
                {%- else -%}
                          {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%  endif %}                     
               </div> 
                   {% endfor %}   
              </div>
           </div>
             </div>
         </image-scroll-slider>
    </div>
      <div class="product-section">
       <div class="shop-title title-wrapper-with-link title-wrapper--self-padded-mobile title-wrapper--no-top-margin content-align--{{ section.settings.column_alignment }}">
    {% if section.settings.heading != blank %}
      <h2 class="title {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
      {% endif %}
      {%- if section.settings.description != blank -%}  
        <p class="description">{{ section.settings.description }}</p>
      {%- endif -%} 
    </div>  
    {%  if section.settings.select_product != blank %}
      <div class="product-container">
          <div class="quotes-slider text-center" data-count="1">    
              <div class="hotspot-product-lists">
               {% render 'card-product-3',
                  card_product: section.settings.select_product,
                  media_aspect_ratio: section.settings.image_ratio,
                  show_vendor: false,
                  show_rating: false,
                  show_quick_add: false,
                  show_new_tag: false,
                  show_secondary_image: true,
                  section_id: section.id
                %}
              </div>       
        </div>    
      </div>
      {% endif%}      
    </div> 
      </div>
    </scroll-the-product>       
    </div>
    </div>    
    </div>
  </div>
</div>


{% schema %}
{
  "name": "scroll the product",
  "class": "section index-section scroll-the-product",
  "max_blocks": 6,
  "settings": [
    {
      "type":"checkbox",
      "id":"page_full_width",
       "default": false,
      "label": "t:sections.all.page_full_width.label"
    },
    {
      "type":"checkbox",
      "id":"page_full_width_spacing",
       "default": false,
      "label": "t:sections.all.page_full_width_spacing.label"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        {
          "value": "accent-1",
          "label": "t:sections.all.colors.accent_1.label"
        },
        {
          "value": "accent-2",
          "label": "t:sections.all.colors.accent_2.label"
        },
        {
          "value": "background-1",
          "label": "t:sections.all.colors.background_1.label"
        },
        {
          "value": "background-2",
          "label": "t:sections.all.colors.background_2.label"
        },
        {
          "value": "inverse",
          "label": "t:sections.all.colors.inverse.label"
        }
      ],
      "default": "background-1",
      "label": "t:sections.all.colors.label"
    },
	{
      "type": "text",
      "id": "heading",
      "label": "t:sections.scroll-the-product.settings.heading.label",
      "default": "Shop the look"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "text",
      "id": "description",
      "default": "Use This Text To Share The Information Which You Like!.",   
      "label": "t:sections.all.description.label"
    },
    {
      "type": "select",
      "id": "column_alignment",
      "options": [
        {
          "value": "left",
          "label": "t:sections.grid-banner.settings.column_alignment.options__1.label"
        },
        {
          "value": "center",
          "label": "t:sections.grid-banner.settings.column_alignment.options__2.label"
        }
      ],
      "default": "center",
      "label": "t:sections.grid-banner.settings.column_alignment.label"
    },
      {
      "type": "image_picker",
      "id": "banner_bg",
      "label": "t:sections.scroll-the-product.settings.banner_bg.label"
    }, 
    {
      "type": "header",
      "content": "t:sections.scroll-the-product.settings.header.content"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.scroll-the-product.settings.image_ratio.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.scroll-the-product.settings.image_ratio.options__2.label"
        },
        {
          "value": "square",
          "label": "t:sections.scroll-the-product.settings.image_ratio.options__3.label"
        }
      ],
      "default": "adapt",
      "label": "t:sections.scroll-the-product.settings.image_ratio.label"
    },
     {
      "type": "image_picker",
      "id": "product_bg",
      "label": "t:sections.scroll-the-product.settings.product_bg.label"
    }, 
    {
        "type" : "product",
        "id" : "select_product",
        "label" : "t:sections.scroll-the-product.settings.select_product.label"
      },
    {
      "type": "header",
      "content": "t:sections.scroll-the-product.settings.product_style.label"
    },
    {
    "type": "select",
    "id": "product_style",
    "options": [
    {
    "value": "grid",
    "label": "t:sections.scroll-the-product.settings.product_style.options__1.label"
    },
    {
    "value": "list",
    "label": "t:sections.scroll-the-product.settings.product_style.options__2.label"
    }
    ],
     "default": "grid",
     "label": "t:sections.scroll-the-product.settings.product_style.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    },
    {
    "type": "header",
    "content": "t:sections.all.custom_class_heading.content"
    },
    {
    "type": "text",
    "id": "custom_class_name",
    "label": "t:sections.all.custom_class_name.label"
    }
  ],
  "blocks": [
    {
      "type": "quote",
      "name": "t:sections.scroll-the-product.blocks.product.name",
      "settings": [       
      {
      "type": "image_picker",
      "id": "spot_image",
      "label": "t:sections.scroll-the-product.blocks.product.settings.spot_image.label"
      }
      ]
    }
  ],
  "presets": [
    {
      "name": "scroll the product",
      "category": "Text",
      "blocks": [
        {
          "type": "quote"
        }
      ]
    }
  ]
}
{% endschema %}


