{%- style -%}
  :root {
  --color-text: navy;
  --color-bg: papayawhip;
  --color-bg-accent: #ecdcc0;
  --size: 35rem;
  --gap: calc(var(--size) / 2);
  --duration: 120s;
  --scroll-start: 0;
  --scroll-end: calc(-100% - var(--gap));
}
   .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }

    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
.marquee_text {
  display: flex;
  overflow: hidden;
  user-select: none;
  gap: var(--gap);
}

.marquee__group {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: space-around;
  gap: 3rem;
  min-width: 100%;
  animation: scroll-x var(--duration) linear infinite;
}

@media (prefers-reduced-motion: reduce) {
  .marquee__group {
    animation-play-state: paused;
  }
}

.marquee--reverse .marquee__group {
  animation-direction: reverse;
  animation-delay: -4s;
}
.marquee-collection .title-wrapper-with-link .title{
    font-size: 4.4rem;
    font-family: var(--font-additional-family);
    font-style: italic;
    font-weight: 400;
    text-transform: capitalize;
  }
@keyframes scroll-x {
  from {
    transform: translateX(var(--scroll-start));
  }
  to {
    transform: translateX(var(--scroll-end));
  }
}

@keyframes scroll-y {
  from {
    transform: translateY(var(--scroll-start));
  }
  to {
    transform: translateY(var(--scroll-end));
  }
}

/* Element styles */
.marquee_text h6 {
  place-items: center;
  width: 100%;
  line-height:normal;
  font-size: 5rem;
  font-family: var(--font-additional-family);
  font-weight:400;
   margin: 0;
  text-transform: capitalize;
}
.marquee_text h6 sup{
  font-size:2.6rem;
}
.marquee_text{position:relative; padding: 25px 0;}  
.marquee_text:after {
    content: "";
    position: absolute;
    background: #D3BD9E;
    width: 100%;
    height: 1px;
    top: 0;
} 
.marquee_text:last-child:before {
    content: "";
    background: #D3BD9E;
    width: 100%;
    position: absolute;
    bottom: 0;
    height: 1px;
}  
/* Parent wrapper */
.wrapper {
  display: flex;
  flex-direction: column;
  gap: 0;
  margin: auto;
  max-width: 100vw;
}


@keyframes fade {
  to {
    opacity: 0;
    visibility: hidden;
  }
}
.marquee__group img{
      width: 118px;
    height: 73px;
}
.collection-marquee .row{position:relative;}
.collection-marquee .row:after{
   content: "";
  display: block;
  position: absolute;
  width: 100%;
  height: 100%;
  background:url({{ section.settings.marquee_image | image_url: width:1920  }});
  background-repeat: no-repeat; left: 0; right: 0; z-index:-1; top:0; bottom:0;    border-radius: 0;
}
@media screen and (max-width: 1199px) {
  .marquee_text h6{font-size:3.6rem;}
}
@media screen and (max-width: 990px) {
.marquee_text h6{font-size:3rem;}
.marquee_text h6 sup { font-size: 2.2rem;}   
.marquee_text{  padding: 10px 0;} 
.marquee-collection .title-wrapper-with-link .title{font-size:4.2rem}  
}    
@media screen and (max-width: 576px) {
.marquee_text h6{font-size:2rem;}
.marquee_text h6 sup { font-size: 1.6rem;}   
.marquee_text{  padding: 10px 0;} 
.marquee__group {gap:1rem;}  
.marquee_text {gap:15rem;}  
.marquee-collection .title-wrapper-with-link .title{font-size:3.2rem}  
}
    
{%- endstyle -%}

<div class="collection-marquee color-{{ section.settings.color_scheme }} gradient {{ section.settings.custom_class_name }}">
  <div class="{% if section.settings.page_full_width %} page-full-width {% else %} page-width {% endif %} {% if section.settings.page_full_width_spacing %} page-full-width_spacing {% endif %}">
    <div class="row section-{{ section.id }}-padding isolate">
      <div class="marquee-collection">
       {%- unless section.settings.title == blank -%}
      <div class="title-wrapper-with-link{% if posts_displayed > 2 %} title-wrapper--self-padded-tablet-down{% else %} title-wrapper--self-padded-mobile{% endif %} title-wrapper--no-top-margin content-align--{{ section.settings.column_alignment }}">
        {%- if section.settings.sub_heading != blank -%}  
         <h6 class="sub-heading">{{ section.settings.sub_heading | escape }}</h6>
         {%- endif -%} 
         {%- if section.settings.title != blank -%}  
          <h2 class="title {{ section.settings.heading_size }}">
            {{ section.settings.title | escape }}
          </h2>
          {%- endif -%} 
          {%- if section.settings.description != blank -%}  
          <p class="description">{{ section.settings.description }}</p>
          {%- endif -%}   
          {%- if section.settings.button_label != blank -%}
            <a {% if section.settings.button_link == blank %} role="link" aria-disabled="true"{% else %} href="{{ section.settings.button_link }}"{% endif %} class="button{% if section.settings.button_style_secondary %} button--secondary{% else %} button--primary{% endif %}">{{ section.settings.button_label | escape }}</a>
          {%- endif -%}
       
      </div>
    {%- endunless -%}    
      <article class="wrapper">
         <div class="marquee_text">
            <div class="marquee__group">
              {% for block in section.blocks %}
                <img src="{{ block.settings.collection.image | image_url: width: 300 }}" width="{{ block.settings.collection.image.width }}" height= "{{ block.settings.collection.image.height }}"/>
              <h6>{{ block.settings.collection.title }} <sup>{{ block.settings.collection.all_products_count }}</sup> </h6>
              {% endfor %}
            </div>
            <div  class="marquee__group">
              {% for block in section.blocks %}
              <img src="{{ block.settings.collection.image | image_url: width: 300 }}"/>
              <h6>{{ block.settings.collection.title }} <sup>{{ block.settings.collection.all_products_count }}</sup></h6>
              {% endfor %}
            </div>   
          </div> 
         <div class="marquee_text marquee--reverse">
            <div class="marquee__group">
              {% for block in section.blocks %}
                <img src="{{ block.settings.collection.image | image_url: width: 300 }}" width="{{ block.settings.collection.image.width }}" height= "{{ block.settings.collection.image.height }}"/>
              <h6>{{ block.settings.collection.title }} <sup>{{ block.settings.collection.all_products_count }}</sup> </h6>
              {% endfor %}
            </div>
            <div  class="marquee__group">
               {% for block in section.blocks %}
                <img src="{{ block.settings.collection.image | image_url: width: 300 }}" width="{{ block.settings.collection.image.width }}" height= "{{ block.settings.collection.image.height }}"/>
              <h6>{{ block.settings.collection.title }} <sup>{{ block.settings.collection.all_products_count }}</sup> </h6>
              {% endfor %}
            </div>   
          </div> 
         <div class="marquee_text">
            <div class="marquee__group">
               {% for block in section.blocks %}
                <img src="{{ block.settings.collection.image | image_url: width: 300 }}" width="{{ block.settings.collection.image.width }}" height= "{{ block.settings.collection.image.height }}"/>
              <h6>{{ block.settings.collection.title }} <sup>{{ block.settings.collection.all_products_count }}</sup> </h6>
              {% endfor %}
            </div>
            <div  class="marquee__group">
               {% for block in section.blocks %}
                <img src="{{ block.settings.collection.image | image_url: width: 300 }}" width="{{ block.settings.collection.image.width }}" height= "{{ block.settings.collection.image.height }}"/>
              <h6>{{ block.settings.collection.title }} <sup>{{ block.settings.collection.all_products_count }}</sup> </h6>
              {% endfor %}
            </div>   
          </div> 
      </article>  
      </div>
    </div>
  </div>
</div>
<script>
const marquees = document.querySelectorAll(".marquee");
const wrapper = document.querySelector(".wrapper");

