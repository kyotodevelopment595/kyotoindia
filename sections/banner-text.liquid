{% style %}
.banner-container {
  background-color: #E31837;
  padding: 20px 40px;
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.banner-text {
  color: #ffffff;
  font-size: 16px;
  line-height: 1.5;
  max-width: 60%;
}

.banner-button {
  background-color: transparent;
  color: #ffffff;
  padding: 8px 32px;
  border: 2px solid #ffffff;
  border-radius: 25px;
  text-decoration: none;
  font-size: 16px;
  transition: all 0.3s ease;
}

.banner-button:hover {
  background-color: #ffffff;
  color: #E31837;
}

@media screen and (max-width: 768px) {
  .banner-container {
    flex-direction: column;
    text-align: center;
    padding: 20px;
    gap: 15px;
  }
  
  .banner-text {
    max-width: 100%;
    margin-bottom: 15px;
  }
}
{% endstyle %}

<div class="banner-container">
  <div class="banner-text">
    {{ 'Lorem ipsum dolor sit amet, consectetuer adipiscing elit. Lorem ipsum dolor sit amet, consectetuer adipiscing elitLorem ipsum dolor sit amet.' }}
  </div>
  <a href="#" class="banner-button">
    Get it
  </a>
</div>