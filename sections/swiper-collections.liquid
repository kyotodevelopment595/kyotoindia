{% schema %}
{
  "name": "Swiper Collections",
  "settings": [
    {
      "type": "color",
      "id": "border_color",
      "label": "Border Color",
      "default": "#ebebeb"
    },
    {
      "type": "range",
      "id": "circle_size",
      "min": 100,
      "max": 700,
      "step": 10,
      "unit": "px",
      "label": "Circle Size",
      "default": 200
    },
    {
      "type": "checkbox",
      "id": "autoplay_enable",
      "label": "Enable Autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_delay",
      "min": 1000,
      "max": 9000,
      "step": 1000,
      "unit": "ms",
      "label": "Autoplay Delay",
      "default": 3000
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom Image"
        },
        {
          "type": "url",
          "id": "custom_link",
          "label": "Custom Link"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Collection Name"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Collection description"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Swiper Collections",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}

<link rel="stylesheet" href="https://unpkg.com/swiper@8/swiper-bundle.min.css">

<section class="swiper-collections">
  <div class="curved-border top"></div>
  <div class="swiper-container">
    <!-- Custom Navigation Arrows -->
    <div class="custom-swiper-button-prev">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M15 18l-6-6 6-6"/>
      </svg>
    </div>
    <div class="custom-swiper-button-next">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M9 18l6-6-6-6"/>
      </svg>
    </div>
    
    <div class="swiper-wrapper">
      {% for block in section.blocks %}
        {% assign collection = collections[block.settings.collection] %}
        <div class="swiper-slide" {{ block.shopify_attributes }} data-index="{{ forloop.index0 }}">
          <a href="{{ block.settings.custom_link | default: collection.url }}" class="collection-link">
            <div class="circle">
              {% if block.settings.image != blank %}
                {{ block.settings.image | image_url: width: section.settings.circle_size | image_tag: loading: 'lazy', class: 'circle-image' }}
              {% elsif collection.image != blank %}
                {{ collection.image | image_url: width: section.settings.circle_size | image_tag: loading: 'lazy', class: 'circle-image' }}
              {% else %}
                <div class="placeholder-image">{{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}</div>
              {% endif %}
            </div>
          </a>
        </div>
      {% endfor %}
    </div>
  </div>
  <div class="curved-border bottom"></div>
</section>

<div class="content-section">
  <h1 class="content-heading">{{ section.blocks[0].settings.heading }}</h1>
  <p class="content-subtitle">{{ section.blocks[0].settings.subtitle }}</p>
  <a href="{{ section.blocks[0].settings.button_link }}" class="content-button">
    <button class="content-button-text">{{ section.blocks[0].settings.button_text }}</button>
  </a>
</div>

<script>
  window.collectionContent = [
    {% for block in section.blocks %}
      {
        heading: {{ block.settings.heading | json }},
        subtitle: {{ block.settings.subtitle | json }},
        buttonText: {{ block.settings.button_text | json }},
        buttonLink: "{{ block.settings.button_link }}"
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ];
</script>

<style>
  .swiper-collections {
    position: relative;
    padding: 8rem 0;
    background:#f0f0f0;
    overflow: hidden;
    z-index: 1;
  }

  .curved-border {
    position: absolute;
    width: 100vw;
    left: 50%;
    transform: translateX(-50%);
    height: 200px;
    background: white;
    border-radius: 50%;
    z-index: 2;
    box-shadow: 0 0 30px rgba(0,0,0,0.05);
  }

  .curved-border.top {
    top: -130px;
    border-bottom: 4px solid {{ section.settings.border_color }};
  }

  .curved-border.bottom {
    bottom: -130px;
    border-top: 4px solid {{ section.settings.border_color }};
  }

  .swiper-container {
    position: relative;
    z-index: 3;
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem 15px;
  }

  .swiper-slide {
   
    width: 100%;
    padding: 0px 0;
  }

  .circle {
    width: 350px;
    height: 350px;
    border-radius: 50%;
    display:flex;
    align-items:center;
    justify-content:center;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    margin: 0 auto;
    position: relative;
    z-index: 4;
    border: 2px solid {{ section.settings.border_color }};
    background: white;
    box-shadow: 0 20px 40px rgba(0,0,0,0.1);
  }
  .circle>img{
    width:300px;
  }

  .circle:hover {
    transform: scale(1.05) rotate(2deg);
    box-shadow: 0 25px 50px rgba(0,0,0,0.15);
  }

  /* Custom Arrow Styles */
  .custom-swiper-button-prev,
  .custom-swiper-button-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 50px;
    height: 50px;
    background: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .custom-swiper-button-prev:hover,
  .custom-swiper-button-next:hover {
    transform: translateY(-50%) scale(1.1);
    box-shadow: 0 8px 25px rgba(0,0,0,0.15);
  }

  .custom-swiper-button-prev svg,
  .custom-swiper-button-next svg {
    width: 24px;
    height: 24px;
    stroke: #333;
  }

  .custom-swiper-button-prev {
    left: 30px;
  }

  .custom-swiper-button-next {
    right: 30px;
  }

  /* Hide default Swiper arrows */
  .swiper-button-prev::after,
  .swiper-button-next::after {
    display: none;
  }

  .content-section {
    text-align: center;
    padding: 0rem 2rem;
    max-width: 800px;
    margin: 2rem auto;
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(10px);
    border-radius: 20px;
    position: relative;
    z-index: 3;
  }
   .content-heading {
      font-size: 6.5rem;
     margin:0;
     font-weight:600;
    }
  .content-button-text{
   padding: 20px 30px;
    margin-top:10px;
    font-size: 1.5rem;
    color: white;
    width: 200px;
    outline: none;
    border: none;
    border-radius: 20px;
    background-color: #ff0000;
  }

  @media (max-width: 768px) {
     .content-button-text{
    padding: 10px 20px;
        font-size: 1.2rem;
        color: white;
        width: 150px;
        outline: none;
        border: none;
        border-radius: 10px;
        background-color: #ff0000;
  }
    .circle {
      width:250px;
      height:250px;
    }
    .circle>img{
    width:200px;
  }

    .swiper-collections {
    position: relative;
    padding: 6rem 0;
    background: white;
    overflow: hidden;
    z-index: 1;
  }
    .custom-swiper-button-prev,
    .custom-swiper-button-next {
      display: none;
    }
    .content-section{
      margin:0;
    }
    .circle {
      width: 250px;
      height: 250px;
    }

    .content-heading {
      font-size: 3.5rem;
    }
  }
</style>

<script src="https://unpkg.com/swiper@8/swiper-bundle.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
  const swiper = new Swiper('.swiper-container', {
    loop: true,
    slidesPerView: 1,
    autoplay: {{ section.settings.autoplay_enable | json }} ? {
      delay: {{ section.settings.autoplay_delay | json }},
      disableOnInteraction: false
    } : false,
    centeredSlides: true,
    spaceBetween: 30,
    grabCursor: true,
    keyboard: { enabled: true },
    navigation: {
      nextEl: '.custom-swiper-button-next',
      prevEl: '.custom-swiper-button-prev',
    },
    on: {
      init: function() {
        updateContent(this.realIndex);
      },
      slideChange: function() {
        updateContent(this.realIndex);
      }
    }
  });

  function updateContent(index) {
    const content = window.collectionContent[index];
    const heading = document.querySelector('.content-heading');
    const subtitle = document.querySelector('.content-subtitle');
    const button = document.querySelector('.content-button');
    const buttonText = document.querySelector('.content-button-text');

    if (content) {
      heading.textContent = content.heading;
      subtitle.textContent = content.subtitle;
      button.href = content.buttonLink;
      buttonText.textContent = content.buttonText;
    }
  }

  // Pause autoplay on hover
  const swiperEl = document.querySelector('.swiper-container');
  if ({{ section.settings.autoplay_enable | json }}) {
    swiperEl.addEventListener('mouseenter', () => swiper.autoplay.stop());
    swiperEl.addEventListener('mouseleave', () => swiper.autoplay.start());
  }
});
</script>