{%- style -%}
.features-section {
  padding: 60px 20px;
  background-color: #f9f9f9;
}
/* .features-grid-section{
  padding: 10px 20px;
  background-color: #f3f3f4;
} */
.heading-wrapper {
  position: relative;
  max-width: 1200px;
  margin: 0 auto 40px;
}

.features-heading {
  text-align: left;
  font-size: 32px;
  position: relative;
  z-index: 2;
  display: inline-block;
  margin: 0;
  background-color: #f9f9f9;
}

.heading-border {
  position: absolute;
  left: -25px !important;
  top: 50%;
  /* transform: translateY(-50%); */
  width: 345px;
  height: 80px;
  border: 1px solid #EE1C25;
  border-radius: 5px;
  z-index: 1;
}

.features-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 30px;
  max-width: 1200px;
  margin: 0 auto;
}

.feature-box {
  z-index: 1;
  background: white;
  padding: 20px;
  border-radius: 10px;
  text-align: center;
}

.feature-image {
  width: 120px;
  height: 120px;
  margin: 0 auto 20px;
}

.feature-image img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.feature-title {
  color: #EE1C25;
  font-size: 20px;
  margin-bottom: 15px;
}

.feature-text {
  font-size: 14px;
  line-height: 1.5;
  color: #333;
}

@media screen and (max-width: 1024px) {
  .features-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media screen and (max-width: 640px) {
  .features-grid {
    grid-template-columns: 1fr;
  }
  
  .heading-wrapper {
    text-align: center;
  }
  
  .features-heading {
    font-size: 24px;
    text-align: center;
    padding: 0 15px;
  }
  
  .heading-border {
    width: 200px;
    height: 60px;
    left: 50%;
    transform: translate(-50%, -50%);
  }
  
  .feature-box {
    max-width: 400px;
    margin: 0 auto;
  }
}
{%- endstyle -%}

<div class="features-section">
  {% if section.settings.heading != blank %}
    <div class="heading-wrapper">
      <div class="heading-border"></div>
      <h2 class="features-heading">{{ section.settings.heading }}</h2>
    </div>
  {% endif %}

  <div class="features-grid-section">
  <div class="features-grid">
    {% for block in section.blocks %}
      <div class="feature-box" {{ block.shopify_attributes }}>
        {% if block.settings.image != blank %}
          <div class="feature-image">
            <img src="{{ block.settings.image | img_url: '240x240' }}"
                 alt="{{ block.settings.title }}"
                 loading="lazy"
                 width="120"
                 height="120">
          </div>
        {% endif %}
        
        {% if block.settings.title != blank %}
          <h3 class="feature-title">{{ block.settings.title }}</h3>
        {% endif %}
        
        {% if block.settings.text != blank %}
          <p class="feature-text">{{ block.settings.text }}</p>
        {% endif %}
      </div>
    {% endfor %}
    </div >
  </div>
</div>

{% schema %}
{
  "name": "Features Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Lorem ipsum Lorem"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Heading Border Color",
      "default": "#EE1C25"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Lorem ipsum"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Lorem ipsum dolor sit amet, consectetuer adipiscing elit sed diam nonummy nibh euismod tincidunt ut laoreet dolore magna aliquam erat"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Features Grid",
      "blocks": [
        {
          "type": "feature"
        },
        {
          "type": "feature"
        },
        {
          "type": "feature"
        },
        {
          "type": "feature"
        }
      ]
    }
  ]
}
{% endschema %}