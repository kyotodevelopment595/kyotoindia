{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
.image-with-banner a.image-banner-heading{   position: relative; font-size: 9rem; font-weight: 700; text-decoration: none; text-transform: uppercase; opacity: 0.3; line-height: 72px; font-family: var(--font-additional-family); transition: opacity .3s ease-in-out; cursor: pointer;}  
.image-with-banner .image-with-banner-wrapper .image-banner-media{position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; opacity: 0; visibility: hidden; transition: all .3s ease-in-out;}
.image-with-banner .image-banner-media img{ width: 100%; height: 100%; object-fit: cover; object-position: 50% 50%;  }
.image-with-banner .image-with-banner ul > li:first-child .image-banner-media, 
.image-with-banner .image-with-banner-wrapper:hover .image-banner-media{ opacity: 1; visibility: visible;}
.image-with-banner .image-with-banner-wrapper.active a.image-banner-heading +  .image-banner-media{ opacity: 1; visibility: visible; }
.image-with-banner .image-with-banner-wrapper.hover  a.image-banner-heading { opacity: 1;  }
.image-with-banner .image-with-banner-wrapper.active  a.image-banner-heading { opacity: 1;}
.image-with-banner .image-with-banner-grid{ position: relative; display: grid; grid: 1fr / 1fr; width: 100%; height: 100%; z-index: 999; padding: 185px 0; border-radius: var(--media-radius);   }
.image-with-banner .image-with-banner-grid ul{ list-style: none; margin: 0 auto; padding: 0;}
.image-with-banner .image-with-banner-wrapper{  display:flex; justify-content: center; align-items: center;} 
.image-with-banner .image-with-banner-grid li:not(:last-child){  padding: 0px 0 81px; }
.image-with-banner a.image-banner-heading:hover{opacity:1;}
  @media screen and (max-width: 1540px) {
  .image-with-banner a.image-banner-heading{ font-size:7rem;}
  .image-with-banner .image-with-banner-grid li:not(:last-child){  padding: 0px 0 60px; }
  .image-with-banner .image-with-banner-grid{padding: 165px 0;}
   }
@media screen and (max-width: 1199px) {
  .image-with-banner a.image-banner-heading{ font-size:5.6rem;}
  .image-with-banner .image-with-banner-grid li:not(:last-child){  padding: 0px 0 40px; }
  .image-with-banner .image-with-banner-grid{padding: 135px 0;}
   }  
 @media screen and (max-width: 800px) {
  .image-with-banner a.image-banner-heading{ font-size:4.8rem; line-height: normal;}
  .image-with-banner .image-with-banner-grid li:not(:last-child){  padding: 0px 0 30px; }
  .image-with-banner .image-with-banner-grid{padding: 100px 0;}
   }   
   @media screen and (max-width: 600px) {
  .image-with-banner a.image-banner-heading{ font-size:3.8rem; line-height: normal;}
  .image-with-banner .image-with-banner-grid li:not(:last-child){  padding: 0px 0 15px; }
  .image-with-banner .image-with-banner-grid{padding: 100px 0;}
   }  
    @media screen and (max-width: 480px) {
  .image-with-banner a.image-banner-heading{ font-size:2.8rem; line-height: normal;}
  .image-with-banner .image-with-banner-grid li:not(:last-child){  padding: 0px 0 15px; }
  .image-with-banner .image-with-banner-grid{padding: 100px 15px;}
   }  
   @media screen and (max-width: 390px) {
  .image-with-banner a.image-banner-heading{ font-size:2.2rem; line-height: normal;}
 .image-with-banner .image-with-banner-grid{padding: 100px 10px;}
   }

/*gym-image-product-tab*/
.image-with-banner.gym-image-product-tab .image-with-banner-grid li { width: fit-content;} 
/* .image-with-banner.gym-image-product-tab .image-with-banner-grid ul{    display: grid; grid-template-columns: 1fr 1fr 1fr;  text-align: center;} */
 .image-with-banner.gym-image-product-tab a.image-banner-heading{font-size:4.4rem; font-weight:400;}
 @media screen and (min-width: 1101px) { 
.image-with-banner.gym-image-product-tab .image-with-banner-grid ul{ width:1635px; display: grid; grid-template-columns: 1fr 1fr 1fr;  text-align: center;justify-items: center;}  
.image-with-banner.gym-image-product-tab .image-with-banner-grid li:first-child { grid-column-start: 1; grid-column-end: 2; display: grid; grid-row: 1;margin-bottom:90px;}  
.image-with-banner.gym-image-product-tab .image-with-banner-grid li:nth-child(2) { grid-column-start: 2; grid-column-end: 3; display: grid; grid-row: 1; margin-bottom:90px;}  
.image-with-banner.gym-image-product-tab .image-with-banner-grid li:nth-child(3) { grid-column-start: 3; grid-column-end: 4; display: grid; grid-row: 1;margin-bottom:90px;}    
.image-with-banner.gym-image-product-tab  .image-with-banner-grid li:nth-child(4) { grid-column-start: 1; grid-column-end: 3; display: grid; grid-row: 2;}  
.image-with-banner.gym-image-product-tab  .image-with-banner-grid li:last-child { grid-column-start: 2; grid-column-end: 4; display: grid; grid-row: 2;}    
.image-with-banner.gym-image-product-tab .image-with-banner-grid li:not(:last-child)  {padding:0;}
 }  
@media screen and (max-width: 1700px) {
  .image-with-banner.gym-image-product-tab .image-with-banner-grid ul{width:100%;}
   }
@media screen and (max-width: 1440px) {
  .image-with-banner.gym-image-product-tab a.image-banner-heading{font-size:3.4rem;}
  .image-with-banner.gym-image-product-tab .image-with-banner-grid li:first-child{margin-bottom: 50px;}
  .image-with-banner.gym-image-product-tab .image-with-banner-grid li:nth-child(2){margin-bottom: 50px;}
  .image-with-banner.gym-image-product-tab .image-with-banner-grid li:nth-child(3){margin-bottom: 50px;}
   } 

@media screen and (max-width: 1100px) {  
 .image-with-banner.gym-image-product-tab .image-with-banner-grid ul{display: grid; grid-template-columns: 1fr 1fr; }  
  .image-with-banner.gym-image-product-tab .image-with-banner-grid li{width:100%;}
  .image-with-banner.gym-image-product-tab .image-with-banner-grid li:last-child{left:50%; position: relative;}
}
@media screen and (max-width: 900px) {
    .image-with-banner.gym-image-product-tab a.image-banner-heading{font-size:2.4rem;}
}
@media screen and (max-width: 768px) {
   .image-with-banner.gym-image-product-tab .image-with-banner-grid ul{display: grid; grid-template-columns: 1fr; } 
   .image-with-banner.gym-image-product-tab .image-with-banner-grid li:first-child{margin-bottom: 20px;}
  .image-with-banner.gym-image-product-tab .image-with-banner-grid li:nth-child(2){margin-bottom: 20px;}
  .image-with-banner.gym-image-product-tab .image-with-banner-grid li:nth-child(3){margin-bottom: 20px;}
  .image-with-banner.gym-image-product-tab .image-with-banner-grid li:nth-child(4){margin-bottom: 20px;}
   .image-with-banner.gym-image-product-tab .image-with-banner-grid li:last-child{left:0; position: relative; margin-bottom: 20px;}
}
  {%- endstyle -%}

<div class="image-with-banner {{ section.settings.custom_class_name }}  color-{{ section.settings.color_scheme }} gradient">
  <div class="{% if section.settings.page_full_width %} page-full-width {% else %} page-width {% endif %} {% if section.settings.page_full_width_spacing %} page-full-width_spacing {% endif %} section-{{ section.id }}-padding isolate">
    <div class="row">
       {%- unless section.settings.title == blank -%}
        <div class="title-wrapper-with-link title-wrapper--self-padded-mobile title-wrapper--no-top-margin content-align--{{ section.settings.column_alignment }}">
         {%- if section.settings.sub_heading != blank -%}  
         <h6 class="sub-heading">{{ section.settings.sub_heading | escape }}</h6>
         {%- endif -%} 
         {%- if section.settings.title != blank -%}  
          <h2 class="title {{ section.settings.heading_size }}">
            {{ section.settings.title | escape }}
          </h2>
          {%- endif -%} 
          {%- if section.settings.description != blank -%}  
          <p class="description">{{ section.settings.description }}</p>
          {%- endif -%}   
          {%- if section.settings.button_label != blank -%}
            <a {% if section.settings.button_link == blank %} role="link" aria-disabled="true"{% else %} href="{{ section.settings.button_link }}"{% endif %} class="button{% if section.settings.button_style_secondary %} button--secondary{% else %} button--primary{% endif %}">{{ section.settings.button_label | escape }}</a>
          {%- endif -%}
        </div>
    {%- endunless -%}
    <div class="image-with-banner-grid">
      <ul>
         {% for block in section.blocks %}    
        <li>
            <div class="image-with-banner-wrapper {% if forloop.first %}active{% endif %}">
          {% if block.settings.image_block_heading != blank %}
            <a class="image-banner-heading">{{ block.settings.image_block_heading }}</a>
            {% endif %} 
           {% if  block.settings.image != blank %}
          <div class="image-banner-media">
            <img
        srcset="{%- if block.settings.image.width >= 375 -%}{{ block.settings.image | image_url: width: 375 }} 375w,{%- endif -%}
          {%- if block.settings.image.width >= 550 -%}{{ block.settings.image | image_url: width: 550 }} 550w,{%- endif -%}
          {%- if block.settings.image.width >= 750 -%}{{ block.settings.image | image_url: width: 750 }} 750w,{%- endif -%}
          {%- if block.settings.image.width >= 1100 -%}{{ block.settings.image | image_url: width: 1100 }} 1100w,{%- endif -%}
          {%- if block.settings.image.width >= 1500 -%}{{ block.settings.image | image_url: width: 1500 }} 1500w,{%- endif -%}
          {%- if block.settings.image.width >= 1780 -%}{{ block.settings.image | image_url: width: 1780 }} 1780w,{%- endif -%}
          {%- if block.settings.image.width >= 2000 -%}{{ block.settings.image | image_url: width: 2000 }} 2000w,{%- endif -%}
          {%- if block.settings.image.width >= 3000 -%}{{ block.settings.image | image_url: width: 3000 }} 3000w,{%- endif -%}
          {%- if block.settings.image.width >= 3840 -%}{{ block.settings.image | image_url: width: 3840 }} 3840w,{%- endif -%}
          {{ block.settings.image | image_url }} {{ block.settings.image.width }}w"
        sizes="{% if block.settings.image_2 != blank and block.settings.stack_images_on_mobile %}(min-width: 750px) 50vw, 100vw{% elsif block.settings.image_2 != blank %}50vw{% else %}100vw{% endif %}"
        src="{{ block.settings.image | image_url: width: 1500 }}"
        loading="lazy"
        alt="{{ block.settings.image.alt | escape }}"
        width="{{ block.settings.image.width }}"
        height="{{ block.settings.image.width | divided_by: block.settings.image.aspect_ratio }}"
        {% if block.settings.image_2 != blank %}class="banner__media-image-half"{% endif %}
      >
       </div>
               {% endif %} 
     </div>        
        </li>
        {% endfor %}        
      </ul>
    </div> 
    </div>
  </div>
</div>
<script>

var imageBannerHeadings = document.querySelectorAll(".image-banner-heading");
imageBannerHeadings.forEach(function(element) {
  element.addEventListener("mouseover", function() {
    const imageWithBanners = document.querySelectorAll(".image-with-banner");
    imageWithBanners.forEach(function(imageWithBanner) {
      imageWithBanner.classList.add("hover");
    });

 
    const imageWithBannerWrappers = document.querySelectorAll(".image-with-banner-wrapper");
    imageWithBannerWrappers.forEach(function(wrapper) {
      wrapper.classList.remove("active");
    });    
    element.parentElement.classList.add("active");
  });

  element.addEventListener("mouseleave", function() { 
    const imageWithBanners = document.querySelectorAll(".image-with-banner");
    imageWithBanners.forEach(function(imageWithBanner) {
      imageWithBanner.classList.remove("hover");
    });
  });
});

</script>
