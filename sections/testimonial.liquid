{%- style -%}
.testimonial-section {
  padding: 80px 0;
  position: relative;
  overflow: hidden;
}

.section-heading-wrapper {
  position: relative;
  margin-bottom: 40px;
  text-align: center;
}

.heading-rectangle {
  position: absolute;
  width: 60%;
  height: 15px;
  background: rgba(255, 99, 71, 0.2);
  bottom: 5px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 1;
}

.section-heading {
  position: relative;
  z-index: 2;
  font-size: 36px;
  margin: 0;
  display: inline-block;
}

.testimonial-card {
  border: 1px solid rgba(0, 0, 0, 0.1);
  border-radius: 10px;
  background: rgba(255, 255, 255, 0.8);
  padding: 20px;
  display: flex;
  gap: 20px;
  margin: 10px;
}

/* .testimonial-image {
  width: 200px;
  height: 200px;
  object-fit: cover;
  border-radius: 8px;
} */

.testimonial-content {
  flex: 1;
}

.testimonial-heading {
  font-size: 24px;
  margin-bottom: 15px;
}

.testimonial-text {
  font-size: 16px;
  line-height: 1.6;
}

.background-rectangle {
  position: absolute;
  border: 2px solid rgba(0, 0, 0, 0.1);
  width: 200px;
  height: 200px;
  z-index: -1;
}

.rectangle-1 {
  top: 10%;
  left: 5%;
}

.rectangle-2 {
  bottom: 15%;
  right: 8%;
}

@media (max-width: 768px) {
  .testimonial-card {
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  
  .testimonial-image {
    width: 150px;
    height: 150px;
  }
  
  .section-heading {
    font-size: 28px;
  }
  
  .heading-rectangle {
    width: 80%;
  }
}
{%- endstyle -%}

<div class="testimonial-section">
  <div class="background-rectangle rectangle-1"></div>
  <div class="background-rectangle rectangle-2"></div>
  
  <div class="section-heading-wrapper">
    <div class="heading-rectangle"></div>
    <h2 class="section-heading">What're They Saying?</h2>
  </div>

  <div class="swiper testimonial-swiper">
    <div class="swiper-wrapper">
      {% for block in section.blocks %}
        <div class="swiper-slide">
          <div class="testimonial-card">
            <img 
              src="{{ block.settings.image | img_url: '400x' }}" 
              alt="{{ block.settings.name }}"
              class="testimonial-image"
              loading="lazy"
            >
            <div class="testimonial-content">
              <h3 class="testimonial-heading">{{ block.settings.name }}</h3>
              <div class="testimonial-text">{{ block.settings.testimonial }}</div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/swiper@8/swiper-bundle.min.js"></script>
<script>
  new Swiper('.testimonial-swiper', {
    slidesPerView: 1.2,
    spaceBetween: 20,
    centeredSlides: true,
    loop: true,
    // autoplay: {
    //   delay: 3000,
    //   disableOnInteraction: false,
    // },
    breakpoints: {
      768: {
        slidesPerView: 1.5,
        spaceBetween: 30,
      }
    }
  });
</script>

{% schema %}
{
  "name": "Testimonials",
  "settings": [],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Customer Image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Customer Name",
          "default": "LOREM IPSUM DOLOR"
        },
        {
          "type": "textarea",
          "id": "testimonial",
          "label": "Testimonial Text",
          "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials Slider",
      "blocks": [
        {
          "type": "testimonial"
        }
      ]
    }
  ]
}
{% endschema %}