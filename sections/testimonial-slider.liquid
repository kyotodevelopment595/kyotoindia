{% style %}
.testimonial-section-v2 {
  padding: 20px 0px 80px 0px;
  position: relative;
  overflow: hidden;
  max-width: 100%;
}

.testimonial-title-wrapper {
  position: relative;
 
}
  .testimonialTextImage{
    margin-bottom:-10%;
  }

.testimonial-title-v2 {
  font-size: 45px;
  font-weight:600;
  position: relative;
  text-align:center;
  z-index: 2;
  margin: 0;
  background: #fff;
  border-radius: 30px;
}

.title-outline {
  text-align:center;
  
  z-index: 1;
}

.testimonial-swiper-v2 {
  position: relative;
  width: 100%;
  padding: 20px 120px;
}

.testimonial-card-v2 {
  height:400px;
  padding: 0px 0px;
  border: 1px solid;
  background: #fff;
  border-radius: 25px;
  overflow: hidden;
  display: flex;
  align-items: stretch;
  box-shadow: 0 0 20px rgba(0, 0, 0, 0.05);
  margin: 10px;
}

.testimonial-image-wrapper {

  position: relative;
}

.testimonial-image-v2 {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.testimonial-content-v2 {
  width:60%;
  padding: 30px 20px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.testimonial-heading-v2 {
  
  color: #ff3b30;
  font-size: 22px;
  margin-bottom: 5px;
  font-weight: 600;
}

.testimonial-text-v2 {
  
  font-size: 16px;
  line-height: 1.6;
  color: #666;
}

/* Swiper Customization */
.testimonial-swiper-v2 .swiper-slide {
  opacity: 0.4;
  transition: opacity 0.3s ease;
}

.testimonial-swiper-v2 .swiper-slide-active {
  opacity: 1;
}

.testimonial-swiper-v2 .swiper-wrapper {
  align-items: center;
}

.swiper-button-prev,
.swiper-button-next {
  position: absolute;
  bottom: -30px;
  width: 40px;
  height: 40px;
  background: #ff3b30;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  cursor: pointer;
  transition: background 0.3s ease-in-out;
}

.swiper-button-prev:hover,
.swiper-button-next:hover {
  background: #e60023;
}

.swiper-button-prev::after,
.swiper-button-next::after {
  font-size: 18px;
  font-weight: bold;
  color: #fff;
}

.swiper-button-prev {
  left: 45%;
}

.swiper-button-next {
  right: 45%;
}

@media screen and (max-width: 768px) {
  .testimonialTextImage{
    margin-bottom:-17%;
  }
  
  .testimonial-card-v2{
    height:200px;
  }
  .testimonial-swiper-v2 {
  position: relative;
  width: 100%;
  padding: 20px 20px;
}

  .swiper-button-prev {
    left: 35%;
  }

  .swiper-button-next {
    right: 35%;
  }
}


/* Responsive Design */
@media screen and (max-width: 768px) {
  .testimonial-section-v2 {
    padding: 20px 0px;
  }

  .testimonial-card-v2 {
    flex-direction: row;
  }

  .testimonial-image-wrapper,
  {
    width: 100%;
  }
  .testimonial-content-v2 {
    width: 80%;
  }

  .testimonial-image-wrapper {
    height: 300px;
  }

  .testimonial-content-v2 {
    padding: 10px;
  }

  .testimonial-title-v2 {
    font-size: 24px;
  }

  .swiper-button-prev,
  .swiper-button-next {
    width: 40px;
    height: 40px;
    font-size: 16px;
  }
}
{% endstyle %}

<div class="testimonial-section-v2">
  <div class="testimonial-title-wrapper">
   <img class="testimonialTextImage" src="https://cdn.shopify.com/s/files/1/0924/0677/6122/files/Words_from_OUR_COMMUNITY_TEXT-01.png?v=1740459324" />
    <div class="title-outline"></div>
  </div>
  <div class="background-rectangle3 rectangle-3"></div>
  
  <div class="swiper testimonial-swiper-v2">
    <div class="swiper-wrapper">
      {% for block in section.blocks %}
        <div class="swiper-slide" {{ block.shopify_attributes }}>
          <div class="testimonial-card-v2">
            <div class="testimonial-image-wrapper">
              {% if block.settings.image %}
                <img 
                  src="{{ block.settings.image | img_url: '800x' }}"
                  alt="Testimonial"
                  class="testimonial-image-v2"
                  loading="lazy"
                >
              {% endif %}
            </div>
            <div class="testimonial-content-v2">
            
              <p class="testimonial-text-v2">{{ block.settings.content }}</p>
                <h3 class="testimonial-heading-v2">{{ block.settings.title }}</h3>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
    
    <!-- Navigation buttons -->

  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  new Swiper('.testimonial-swiper-v2', {
    slidesPerView: 1,
    centeredSlides: false,
    spaceBetween: 0,
    grabCursor: true,
    speed: 800,
    effect: 'slide',
    touchRatio: 1,
    resistance: false,
    resistanceRatio: 0,
    mousewheel: {
      forceToAxis: true
    },
    keyboard: {
      enabled: true
    },
    navigation: {
      nextEl: '.swiper-button-next',
      prevEl: '.swiper-button-prev',
    },
    breakpoints: {
      768: {
        slidesPerView:1.5,
        spaceBetween: 40
      }
    }
  });
});

</script>

{% schema %}
{
  "name": "Testimonial Slider V2",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "What're They Saying?"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Testimonial Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "LOREM IPSUM DOLOR"
        },
        {
          "type": "textarea",
          "id": "content",
          "label": "Content",
          "default": "Lorem ipsum dolor sit amet, consectetuer adipiscing elit."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonial Slider V2",
      "category": "Custom Content"
    }
  ]
}
{% endschema %}
