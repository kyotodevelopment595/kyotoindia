{% schema %}
{
  "name": "Curved Product Slider",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "color",
      "id": "circle_color",
      "label": "Circle Color",
      "default": "#fff"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Products"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "max_blocks": 10,
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "slide_image",
          "label": "Slide Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Curved Product Slider",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide"
        },
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}

{{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag }}
{{ 'swiper-bundle.min.js' | asset_url | script_tag }}

<style>
.curve-slider-container {
  position: relative;
  padding: 40px 0 120px 0px;
  overflow: hidden;
  /* max-width: 1400px; */
  margin: 0 auto;
}

.curve-semi-circle {
  z-index: -1;
}

.curve-top-circle {
  box-shadow: 0 -10px 30px rgba(0, 0, 0, 0.7);
  bottom: 85%;
  width: 170%;
  height: 1000px;
  background-color: {{ section.settings.circle_color }};
  border-radius: 100%;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

.curve-bottom-circle {
  box-shadow: 0 15px 30px rgba(0, 0, 0, 0.7);
  top: 75%;
  width: 170%;
  height: 1000px;
  background-color: {{ section.settings.circle_color }};
  border-radius: 100%;
  position: absolute;
  bottom: -350px;
  left: 50%;
  transform: translateX(-50%);
}

.curve-swiper {
  width: 100%;
  padding: 90px 0 0px;
}

.curve-swiper .swiper-wrapper {
  align-items: center;
}

.curve-swiper .swiper-slide {
  width: 300px;
  opacity: 0.5;
  filter: blur(4px);
  transition: all 0.3s ease;
}

.curve-swiper .swiper-slide-active {
  opacity: 1;
  filter: blur(0);
  transform: scale(0.9);
}

.product-card {
  display: block;
  text-decoration: none;
  text-align: center;
}

.product-image-wrapper {
  width: 100%;
  height: 400px;
  margin-bottom: 1rem;
  border-radius: 8px;
  overflow: hidden;
}

.product-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.product-title {
  color: #333;
  font-size: 2rem;
  margin-top: 1rem;
  text-align: center;
  font-weight: 500;
}

.curve-button-wrapper {
  text-align: center;
  margin-top: 30px;
  position: relative;
  z-index: 1;
}

.curve-button {
  margin-top:30px;
  display: inline-block;
  padding: 1.5rem 5rem;
  background-color: #ff4444;
  color: #fff;
  text-decoration: none;
  border-radius: 10px;
  font-weight: 600;
  font-size: 24px;
  transition: all 0.3s ease;
}

.curve-button:hover {
  background-color: #333;
  transform: translateY(-2px);
}

.curve_heading {
  font-size: 42px;
  font-weight: 700;
  text-align: center;
}

@media screen and (max-width: 768px) {
  .curve-slider-container {
    padding: 20px 0;
  }
  
  .product-image-wrapper {
    height: 280px;
  }
  
  .curve-semi-circle {
    height: 100px;
  }
  
  .curve-top-circle {
    top: -50px;
  }
  
  .curve-bottom-circle {
    bottom: -50px;
  }
  
  .curve_heading {
    font-size: 32px;
  }
}

@media screen and (max-width: 480px) {
  .product-image-wrapper {
    height: 240px;
  }
  
  .curve-button {
    padding: 10px 24px;
    font-size: 14px;
  }
  
  .product-title {
    font-size: 1rem;
  }
  
  .curve_heading {
    font-size: 28px;
  }
}
</style>

<div class="curve-slider-container">
  <h2 class="curve_heading">{{ section.settings.heading }}</h2>
  <div class="curve-semi-circle curve-top-circle"></div>
  <div class="curve-semi-circle curve-bottom-circle"></div>
  
  <div class="curve-swiper swiper">
    <div class="swiper-wrapper">
      {% if section.settings.collection != blank %}
        {% for product in section.settings.collection.products %}
          <div class="swiper-slide">
            <a href="{{ product.url }}" class="other-product-card">
              <div class="product-image-wrapper">
                {% if product.featured_image %}
                  <img 
                    src="{{ product.featured_image | img_url: 'master' }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    class="product-image"
                    loading="lazy"
                  >
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag: 'product-image' }}
                {% endif %}
              </div>
              <h3 class="product-title">{{ product.title }}</h3>
            </a>
          </div>
        {% endfor %}
      {% endif %}
      
      {% for block in section.blocks %}
        <div class="swiper-slide" {{ block.shopify_attributes }}>
          {% if block.settings.slide_image %}
            <div class="product-image-wrapper">
              {{ block.settings.slide_image | img_url: 'master' | img_tag: '', 'product-image' }}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
  
  {% if section.settings.button_link != blank and section.settings.button_text != blank %}
    <div class="curve-button-wrapper">
      <a href="{{ section.settings.button_link }}" class="curve-button">
        {{ section.settings.button_text }}
      </a>
    </div>
  {% endif %}
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const swiper = new Swiper('.curve-swiper', {
    slidesPerView: 1.5,
    centeredSlides: true,
    spaceBetween: 20,
    loop: true,
    speed: 3000,    
    
    autoplay: {
      delay: 2000,
      disableOnInteraction: false
    },
    effect: 'coverflow',
    coverflowEffect: {
      rotate: 0,
      stretch: 0,
      depth: 100,
      modifier: 1,
      slideShadows: false
    },
    breakpoints: {
      480: {
        slidesPerView: 2,
        spaceBetween: 30
      },
      768: {
        slidesPerView: 3,
        spaceBetween: 40
      }
    }
  });
});
</script>