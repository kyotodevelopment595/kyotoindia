{{ 'page-wishlist.css' | asset_url | stylesheet_tag }}
{%- style -%}
    .section-wishlistTemplate-padding {
    padding-top: {{ 100 | times: 0.50 | round: 0 }}px;
    padding-bottom: {{ 40 | times: 0.50 | round: 0 }}px;
  }
   @media screen and (min-width: 576px) and (max-width: 749px){
   .section-wishlistTemplate-padding {
    padding-top: {{100 | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ 40 | times: 0.75 | round: 0 }}px;
  }
   }
  @media screen and (min-width: 750px) {
    .section-wishlistTemplate-padding {
      padding-top: 100px;
      padding-bottom: 40px;
    }
  }
{%- endstyle -%}
  
<div class=" page-full-width page-full-width_spacing  wishlist section-wishlistTemplate-padding isolate">
  <div class="row">
  <dtx-wishlist-grid grid_type="wishList">
    <div class="dtx-grid-empty center show-slow">
      <h2>{{ 'products.wishlist.no_records' | t }}</h2>
      <a href="https://kyotoindia.in/collections" class=" button button--primary">
        {{ 'general.continue_shopping' | t }}
      </a>
    </div>

    <table class="dtx-table">      
      <tbody class="slick-wrapper">
        <tr id="row_{item.product_handle}" class="grid_template wishlist-wishlistTemplate" style="display: none;">         
          <td class="product-thumbnail">
            <a href="{item.product_url}" class="product-thumbnail-img">
              <img loading="lazy" src="{item.product_image}" alt="{item.product_title}" width="" height="">
            </a>            
              <p class="product-vendor-cart">  {item.product_vendor}</p>
              <a href="{item.product_url}" class="product-name">{item.product_title}</a>
              <p class="product-price-cart">  {item.money_price}</p>             
            <dtx-remove-wish-item grid_type="wishList">
              <a href="javascript:void(0);" data-product_handle="{item.product_handle}" class="remove-item  product-cart">
                {% render 'icon-close' %}
              </a>
            </dtx-remove-wish-item>
          </td>
          <!-- <td class="product-availability-cart">
            {item.available}
          </td>        
           <td class="product-type-cart">
            {item.product_type}
          </td>
           <td class="product-sku-cart">
            {item.product_sku}
          </td>          
          <td class="product-wishlist-cart">
            <a href="{item.product_url}" data-product-variant-id="{item.variant_id}" class="dt-sc-btn button product-cart">
              Select Options
            </a>
          </td>         -->
        </tr>
      </tbody>
    </table>
  </dtx-wishlist-grid>
</div>
</div>